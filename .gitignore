# CresceBR B2B Marketplace — .gitignore

# ──────────────────────────────────────────────
# Dependencies
# ──────────────────────────────────────────────
**/node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# ──────────────────────────────────────────────
# Build & Compilation
# ──────────────────────────────────────────────
**/dist/
**/build/
.next/
out/

# ──────────────────────────────────────────────
# Environment & Secrets
# ──────────────────────────────────────────────
.env
.env.local
.env.test
.env.staging
.env.production
.env.development.local
.env.test.local
.env.production.local
.env.*.local

# ──────────────────────────────────────────────
# Logs
# ──────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
pnpm-debug.log*

# ──────────────────────────────────────────────
# Test & Coverage
# ──────────────────────────────────────────────
**/coverage/
.nyc_output/
*.test.db
test.sqlite

# ──────────────────────────────────────────────
# TypeScript Cache
# ──────────────────────────────────────────────
*.tsbuildinfo
.tscache/

# ──────────────────────────────────────────────
# Tool & Linter Caches
# ──────────────────────────────────────────────
.npm
.eslintcache
.prettiercache
.cache/
.parcel-cache/
.vitest/

# ──────────────────────────────────────────────
# IDE & Editors
# ──────────────────────────────────────────────
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.sublime-workspace
*.sublime-project

# ──────────────────────────────────────────────
# Operating System
# ──────────────────────────────────────────────
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# ──────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3
*.db.backup
*.db.bak
*.sqlite.backup

# ──────────────────────────────────────────────
# Uploads & User Content
# ──────────────────────────────────────────────
uploads/
backend/uploads/

# ──────────────────────────────────────────────
# Docker
# ──────────────────────────────────────────────
docker-data/
.docker/

# ──────────────────────────────────────────────
# Sequelize local config
# ──────────────────────────────────────────────
config/config.local.json
backend/config/config.json

# ──────────────────────────────────────────────
# Git artifacts
# ──────────────────────────────────────────────
.git-rewrite/
filter-repo/
*.orig

# ──────────────────────────────────────────────
# Temporary files
# ──────────────────────────────────────────────
*.tmp
*.temp
*.swp
*~
\#*\#

# ──────────────────────────────────────────────
# Claude Code (keep commands, ignore local settings)
# ──────────────────────────────────────────────
.claude/settings.local.json
.claude/projects/
.claude/todos/

# ──────────────────────────────────────────────
# Shared build output
# ──────────────────────────────────────────────
shared/dist/

# ──────────────────────────────────────────────
# AI / prompt artifacts (not project source)
# ──────────────────────────────────────────────
docs/delegation-prompt-sonnet.md
