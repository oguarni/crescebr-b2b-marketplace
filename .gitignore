# CresceBR B2B Marketplace — .gitignore

# ──────────────────────────────────────────────
# Dependencies
# ──────────────────────────────────────────────
**/node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# ──────────────────────────────────────────────
# Build & Compilation
# ──────────────────────────────────────────────
**/dist/
**/build/
.next/
out/

# ──────────────────────────────────────────────
# Environment & Secrets
# ──────────────────────────────────────────────
.env
.env.local
.env.test
.env.staging
.env.production
.env.development.local
.env.test.local
.env.production.local
.env.*.local

# ──────────────────────────────────────────────
# Keys, certificates & service-account credentials
# (never commit — GCP/Cloud Run/Firebase deploy target)
# ──────────────────────────────────────────────
*.pem
*.key
*.p12
*.pfx
*-key.json
*-keyfile.json
service-account*.json
serviceAccount*.json
gcp-*.json
google-credentials*.json
credentials.json
.gcp/

# ──────────────────────────────────────────────
# Logs
# ──────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
pnpm-debug.log*

# ──────────────────────────────────────────────
# Firebase
# ──────────────────────────────────────────────
.firebase/
firebase-debug.log*
firebase-debug.*.log*
# Hosting public dir is intentionally empty (rewrites go to Cloud Run); keep only
# the placeholder, never any build assets accidentally copied in.
/firebase-public/*
!/firebase-public/.gitkeep

# ──────────────────────────────────────────────
# Test & Coverage
# ──────────────────────────────────────────────
**/coverage/
.nyc_output/
*.test.db
test.sqlite

# ──────────────────────────────────────────────
# TypeScript Cache
# ──────────────────────────────────────────────
*.tsbuildinfo
.tscache/

# ──────────────────────────────────────────────
# Tool & Linter Caches
# ──────────────────────────────────────────────
.npm
.eslintcache
.prettiercache
.cache/
.parcel-cache/
.vite/
.vitest/

# ──────────────────────────────────────────────
# IDE & Editors
# ──────────────────────────────────────────────
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.sublime-workspace
*.sublime-project

# ──────────────────────────────────────────────
# Operating System
# ──────────────────────────────────────────────
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# ──────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3
*.db.backup
*.db.bak
*.sqlite.backup

# ──────────────────────────────────────────────
# Uploads & User Content
# ──────────────────────────────────────────────
uploads/
backend/uploads/

# ──────────────────────────────────────────────
# Docker
# ──────────────────────────────────────────────
docker-data/
.docker/

# ──────────────────────────────────────────────
# Sequelize local config
# ──────────────────────────────────────────────
config/config.local.json
backend/config/config.json

# ──────────────────────────────────────────────
# Git artifacts
# ──────────────────────────────────────────────
.git-rewrite/
filter-repo/
*.orig

# ──────────────────────────────────────────────
# Temporary files
# ──────────────────────────────────────────────
*.tmp
*.temp
*.swp
*~
\#*\#

# ──────────────────────────────────────────────
# Claude Code (keep commands, ignore local settings)
# ──────────────────────────────────────────────
.claude/settings.local.json
.claude/projects/
.claude/todos/
.claude/skills/
.claude/*.lock
.claude/scheduled_tasks.lock
.claude/.session_*
.claude/cache/
.claude/logs/

# ──────────────────────────────────────────────
# Shared build output
# ──────────────────────────────────────────────
shared/dist/

# ──────────────────────────────────────────────
# Marketing assets (not project source)
# ──────────────────────────────────────────────
docs/marketing/

# ──────────────────────────────────────────────
# AI / prompt artifacts (not project source)
# ──────────────────────────────────────────────
docs/delegation-prompt-sonnet.md
*session-is-being-continued*.txt
*-conversation*.txt
*-transcript*.txt
Project Diagnostic.md
*-diagnostic*.md
audit-report*.md
*-audit-report.md
