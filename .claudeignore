# Claude Code — Context Ignore
# Skip files that add noise without useful code context

# ──────────────────────────────────────────────
# Dependencies (massive, not code context)
# ──────────────────────────────────────────────
**/node_modules/

# ──────────────────────────────────────────────
# Lock files (large, generated)
# ──────────────────────────────────────────────
package-lock.json
**/package-lock.json
yarn.lock
pnpm-lock.yaml

# ──────────────────────────────────────────────
# Build outputs
# ──────────────────────────────────────────────
**/dist/
**/build/
shared/dist/
.next/
out/

# ──────────────────────────────────────────────
# Test & Coverage reports
# ──────────────────────────────────────────────
**/coverage/
.nyc_output/
*.test.db
*.db
*.sqlite

# ──────────────────────────────────────────────
# Logs
# ──────────────────────────────────────────────
*.log
logs/

# ──────────────────────────────────────────────
# Caches & generated
# ──────────────────────────────────────────────
.cache/
.parcel-cache/
.vitest/
.eslintcache
.prettiercache
*.tsbuildinfo
.tscache/
*.tmp
*.temp

# ──────────────────────────────────────────────
# IDE / OS
# ──────────────────────────────────────────────
.idea/
.vscode/
*.sublime-workspace
.DS_Store
Thumbs.db

# ──────────────────────────────────────────────
# Environment & secrets
# ──────────────────────────────────────────────
.env
.env.local
.env.*.local
.env.test
.env.staging
.env.production

# ──────────────────────────────────────────────
# Uploads & user content
# ──────────────────────────────────────────────
uploads/
backend/uploads/

# ──────────────────────────────────────────────
# Git internals & artifacts
# ──────────────────────────────────────────────
.git/
.git-rewrite/
filter-repo/
*.orig

# ──────────────────────────────────────────────
# Database backups
# ──────────────────────────────────────────────
*.db.backup
*.db.bak
*.sqlite.backup

# ──────────────────────────────────────────────
# Binary / media assets (no code context)
# ──────────────────────────────────────────────
*.png
*.jpg
*.jpeg
*.gif
*.svg
*.ico
*.woff
*.woff2
*.ttf
*.eot
*.mp4
*.webm
*.pdf

# ──────────────────────────────────────────────
# Husky (boilerplate hooks)
# ──────────────────────────────────────────────
.husky/

# ──────────────────────────────────────────────
# Docker
# ──────────────────────────────────────────────
docker-data/
.docker/
Dockerfile*
**/Dockerfile*
docker-compose.yml

# ──────────────────────────────────────────────
# GitHub workflows (CI config, not code logic)
# ──────────────────────────────────────────────
.github/workflows/

# ──────────────────────────────────────────────
# Docs (design prompts, images, non-code)
# ──────────────────────────────────────────────
docs/

# ──────────────────────────────────────────────
# Migrations & seeders (generated SQL boilerplate)
# ──────────────────────────────────────────────
backend/migrations/
backend/seeders/

# ──────────────────────────────────────────────
# Config files (boilerplate, not code logic)
# ──────────────────────────────────────────────
.prettierrc.json
.prettierignore
LICENSE
*.example
**/.env.example
backend/config/
backend/nodemon.json

# ──────────────────────────────────────────────
# Claude memory (private, not code context)
# ──────────────────────────────────────────────
.claude/projects/
.claude/todos/

# ──────────────────────────────────────────────
# Migration scripts (one-time, not core logic)
# ──────────────────────────────────────────────
backend/scripts/

# ──────────────────────────────────────────────
# AI / prompt artifacts (not project source)
# ──────────────────────────────────────────────
*session-is-being-continued*.txt
*-conversation*.txt
Project Diagnostic.md
