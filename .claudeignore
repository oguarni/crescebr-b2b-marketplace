# Claude Code — Context Ignore
# Skip files that add noise without useful code context

# ──────────────────────────────────────────────
# Dependencies (massive, not code context)
# ──────────────────────────────────────────────
**/node_modules/

# ──────────────────────────────────────────────
# Lock files (large, generated)
# ──────────────────────────────────────────────
package-lock.json
**/package-lock.json
yarn.lock
pnpm-lock.yaml

# ──────────────────────────────────────────────
# Build outputs
# ──────────────────────────────────────────────
**/dist/
**/build/
.next/
out/

# ──────────────────────────────────────────────
# Test & Coverage reports
# ──────────────────────────────────────────────
**/coverage/
.nyc_output/
*.test.db
*.db
*.sqlite

# ──────────────────────────────────────────────
# Logs
# ──────────────────────────────────────────────
*.log
logs/

# ──────────────────────────────────────────────
# Caches & generated
# ──────────────────────────────────────────────
.cache/
.parcel-cache/
.vitest/
.eslintcache
.prettiercache
*.tsbuildinfo
.tscache/
*.tmp
*.temp

# ──────────────────────────────────────────────
# IDE / OS
# ──────────────────────────────────────────────
.idea/
.vscode/
*.sublime-workspace
.DS_Store
Thumbs.db

# ──────────────────────────────────────────────
# Environment & secrets
# ──────────────────────────────────────────────
.env
.env.local
.env.*.local

# ──────────────────────────────────────────────
# Uploads & user content
# ──────────────────────────────────────────────
uploads/
backend/uploads/

# ──────────────────────────────────────────────
# Git internals & git artifacts
# ──────────────────────────────────────────────
.git/
.git-rewrite/
filter-repo/
*.orig

# ──────────────────────────────────────────────
# Database backups
# ──────────────────────────────────────────────
*.db.backup
*.db.bak
*.sqlite.backup

# ──────────────────────────────────────────────
# Binary / media assets (no code context)
# ──────────────────────────────────────────────
*.png
*.jpg
*.jpeg
*.gif
*.svg
*.ico
*.woff
*.woff2
*.ttf
*.eot

# ──────────────────────────────────────────────
# Husky internals (boilerplate scripts)
# ──────────────────────────────────────────────
.husky/_/

# ──────────────────────────────────────────────
# Docker
# ──────────────────────────────────────────────
docker-data/
.docker/

# ──────────────────────────────────────────────
# GitHub workflows (CI config, not code logic)
# ──────────────────────────────────────────────
.github/workflows/

# ──────────────────────────────────────────────
# Docs (design prompts, image prompts, logos — not code)
# ──────────────────────────────────────────────
docs/

# ──────────────────────────────────────────────
# Shared build output (generated from source)
# ──────────────────────────────────────────────
shared/dist/

# ──────────────────────────────────────────────
# Claude memory (private, not code context)
# ──────────────────────────────────────────────
.claude/projects/
.claude/todos/

# ──────────────────────────────────────────────
# Husky hooks (boilerplate, not code context)
# ──────────────────────────────────────────────
.husky/
