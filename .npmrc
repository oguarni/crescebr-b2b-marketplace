# Security hardening (supply-chain mitigation)
# Block automatic execution of pre/post-install lifecycle scripts from dependencies.
ignore-scripts=true

# NOTE: this repo's backend depends on `sqlite3` (a native module). With
# ignore-scripts=true its build/prebuilt-binary step will NOT run on a plain
# `npm install`. When you need to (re)build it, run that one install with:
#   npm install sqlite3 --foreground-scripts --ignore-scripts=false
