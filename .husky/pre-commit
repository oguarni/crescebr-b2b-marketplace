# Drop the PREFIX env var to avoid an NVM conflict under GitHub Desktop
unset PREFIX

# Load NVM so Node and npm are on PATH
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"

# Secret scan on staged changes (credential-leak / supply-chain guard).
# Blocks the commit if gitleaks finds a secret. Uses .gitleaks.toml (allowlist
# for known placeholders/fixtures). Fails open with a warning if gitleaks is not
# installed, so the hook never blocks a commit just because the tool is missing.
#   Install (Linux/macOS): https://github.com/gitleaks/gitleaks#installing
#   Install (Windows):      winget install gitleaks
# Resolve the gitleaks binary. GUI clients (e.g. GitHub Desktop) may not have the
# updated PATH, so fall back to the Windows winget user-install location.
GITLEAKS_BIN=""
if command -v gitleaks >/dev/null 2>&1; then
  GITLEAKS_BIN="gitleaks"
elif [ -x "$LOCALAPPDATA/Microsoft/WinGet/Links/gitleaks.exe" ]; then
  GITLEAKS_BIN="$LOCALAPPDATA/Microsoft/WinGet/Links/gitleaks.exe"
fi

if [ -n "$GITLEAKS_BIN" ]; then
  "$GITLEAKS_BIN" git --staged --redact --no-banner || {
    echo "❌ gitleaks blocked the commit: a potential secret was found in staged changes."
    echo "   Review above. If it is a verified false positive, add a 'gitleaks:allow'"
    echo "   comment on the line or extend the allowlist in .gitleaks.toml."
    exit 1
  }
else
  echo "⚠️  gitleaks not installed — skipping secret scan (install: https://github.com/gitleaks/gitleaks#installing)"
fi

# Run lint-staged (which in turn runs the linters)
./node_modules/.bin/lint-staged
